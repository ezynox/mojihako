# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Web source files
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.xml  text eol=lf
*.txt  text eol=lf
*.svg  text eol=lf

# Images and binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary